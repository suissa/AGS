# GitHub Personal Access Token (required for GitHub API calls)
# Scopes needed: repo, project, workflow, wiki
GITHUB_TOKEN=

# GitHub owner (user or org)
GITHUB_OWNER=

# Default repository name
GITHUB_REPO=

# LLM Provider: openai | anthropic | local | mock
LLM_PROVIDER=mock

# OpenAI-compatible API base URL
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Anthropic API key
ANTHROPIC_API_KEY=

# Local LLM HTTP endpoint
LOCAL_LLM_URL=http://localhost:11434/api/generate

# AGS mode: simple | allascode
AGS_MODE=simple

# Enable TUI
AGS_TUI=false

# Dry run mode (no real GitHub calls)
AGS_DRY_RUN=false
